# Enforce LF line endings in the repository regardless of OS.
* text=auto eol=lf

# Rust source
*.rs text eol=lf

# Config / data files
*.toml text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Shell scripts always LF
*.sh text eol=lf

# Windows batch files keep CRLF on checkout
*.bat text eol=crlf
*.cmd text eol=crlf
